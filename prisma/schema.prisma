// prisma/schema.prisma
// GlobeX — Event database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id        String   @id @default(cuid())
  city      String
  country   String
  lat       Float
  lng       Float
  name      String
  type      String   @default("LIVE EVENT")
  users     String
  category  String
  duration  String
  color     String   @default("#00FFFF")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
